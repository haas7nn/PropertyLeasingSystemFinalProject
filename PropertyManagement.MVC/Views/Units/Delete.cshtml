@model PropertyManagement.MVC.Models.UnitViewModel
@{ ViewData["Title"] = "Delete Unit"; }
<div class="page-wrap" style="padding-top:2rem;max-width:480px">
  <div class="ph">
    <div><div class="ph-title">Delete Unit</div>
    <ol class="breadcrumb"><li class="breadcrumb-item"><a asp-action="Index">Units</a></li><li class="breadcrumb-item active">Delete</li></ol></div>
  </div>
  <div class="card p-4">
    <div style="display:flex;align-items:flex-start;gap:1rem;margin-bottom:1.5rem">
      <div style="width:48px;height:48px;background:#fee2e2;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:var(--red);flex-shrink:0">
        <i class="bi bi-trash"></i>
      </div>
      <div>
        <div class="fw-700" style="font-size:1rem;margin-bottom:.25rem">Delete Unit @Model.UnitNumber?</div>
        <div style="font-size:.84rem;color:var(--muted)">Units with lease history cannot be deleted.</div>
      </div>
    </div>
    <div style="background:var(--surface);border-radius:10px;padding:1rem;margin-bottom:1.5rem;font-size:.84rem">
      <div style="display:flex;justify-content:space-between;margin-bottom:.3rem"><span style="color:var(--muted)">Type</span><span class="fw-600">@Model.Type</span></div>
      <div style="display:flex;justify-content:space-between;margin-bottom:.3rem"><span style="color:var(--muted)">Rent</span><span class="fw-600">BD @Model.MonthlyRent.ToString("N2")</span></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--muted)">Status</span><span class="fw-600">@Model.AvailabilityStatus</span></div>
    </div>
    <div style="display:flex;gap:10px">
      <form asp-action="Delete" asp-route-id="@Model.UnitId" method="post" style="display:inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Confirm Delete</button>
      </form>
      <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
  </div>
</div>
