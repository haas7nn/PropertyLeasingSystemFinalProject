@model PropertyManagement.MVC.Models.UnitViewModel

<div class="container mt-4">
    <h2>Edit Unit</h2>
    <hr />

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="UnitId" />

        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="UnitNumber" class="form-label">Unit Number</label>
                    <input asp-for="UnitNumber" class="form-control border-dark-subtle" />
                    <span asp-validation-for="UnitNumber" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Type" class="form-label">Type</label>
                    <input asp-for="Type" class="form-control border-dark-subtle" />
                    <span asp-validation-for="Type" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MonthlyRent" class="form-label">Monthly Rent</label>
                    <input asp-for="MonthlyRent" class="form-control border-dark-subtle" />
                    <span asp-validation-for="MonthlyRent" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AvailabilityStatus" class="form-label">Availability Status</label>
                    <select asp-for="AvailabilityStatus" class="form-select border-dark-subtle">
                        <option value="Available">Available</option>
                        <option value="Occupied">Occupied</option>
                        <option value="Maintenance">Maintenance</option>
                    </select>
                </div>
            </div>

            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="Bedrooms" class="form-label">Bedrooms</label>
                    <input asp-for="Bedrooms" type="number" class="form-control border-dark-subtle" />
                </div>

                <div class="mb-3">
                    <label asp-for="Bathrooms" class="form-label">Bathrooms</label>
                    <input asp-for="Bathrooms" type="number" class="form-control border-dark-subtle" />
                </div>

                <div class="mb-3">
                    <label asp-for="SizeInSqFt" class="form-label">Size (sqft)</label>
                    <input asp-for="SizeInSqFt" type="number" class="form-control border-dark-subtle" />
                </div>

                <div class="mb-3">
                    <label asp-for="Amenities" class="form-label">Amenities</label>
                    <textarea asp-for="Amenities" class="form-control border-dark-subtle" rows="1"></textarea>
                </div>
            </div>
        </div>

        <div class="d-flex gap-3 align-items-center mt-4">
            <button type="submit" class="btn btn-outline-dark px-4">Save Changes</button>
            <a asp-action="Index" class="text-dark text-decoration-none">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}