@model PropertyManagement.MVC.Models.UnitViewModel
@{
    ViewData["Title"] = "Unit Details";
    var sc = Model.AvailabilityStatus switch {
        "Available"   => "s-available",
        "Occupied"    => "s-occupied",
        _             => "s-partial"
    };
}

<div class="page-wrap" style="padding-top:2rem;max-width:700px">
  <div class="ph">
    <div>
      <div class="ph-title">Unit @Model.UnitNumber</div>
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Units</a></li>
        <li class="breadcrumb-item active">Details</li>
      </ol>
    </div>
    <div style="display:flex;gap:8px">
      <a asp-action="Edit" asp-route-id="@Model.UnitId" class="btn btn-secondary btn-sm"><i class="bi bi-pencil"></i> Edit</a>
      <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
  </div>

  <div class="card p-0" style="overflow:hidden">
    <div style="background:var(--navy);padding:1.5rem;display:flex;align-items:center;justify-content:space-between">
      <div style="display:flex;align-items:center;gap:1rem">
        <div style="width:48px;height:48px;background:rgba(99,102,241,.35);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#fff">
          <i class="bi bi-door-closed-fill"></i>
        </div>
        <div>
          <div style="color:#fff;font-weight:700;font-size:1.1rem">Unit @Model.UnitNumber</div>
          <div style="color:rgba(255,255,255,.45);font-size:.8rem">@Model.BuildingName &nbsp;·&nbsp; @Model.Type</div>
        </div>
      </div>
      <span class="badge @sc">@Model.AvailabilityStatus</span>
    </div>
    <div class="p-4">
      <div class="row g-3">
        <div class="col-6 col-md-3">
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1rem;text-align:center">
            <div style="font-size:.68rem;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);font-weight:700">Bedrooms</div>
            <div style="font-size:1.4rem;font-weight:700;margin-top:4px">@(Model.Bedrooms?.ToString() ?? "N/A")</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1rem;text-align:center">
            <div style="font-size:.68rem;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);font-weight:700">Bathrooms</div>
            <div style="font-size:1.4rem;font-weight:700;margin-top:4px">@(Model.Bathrooms?.ToString() ?? "N/A")</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1rem;text-align:center">
            <div style="font-size:.68rem;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);font-weight:700">Size</div>
            <div style="font-size:1.1rem;font-weight:700;margin-top:4px">
              @Model.SizeInSqFt<span style="font-size:.75rem;font-weight:400"> sqft</span>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;padding:1rem;text-align:center">
            <div style="font-size:.68rem;text-transform:uppercase;letter-spacing:.06em;color:#2563eb;font-weight:700">Monthly Rent</div>
            <div style="font-size:1.1rem;font-weight:700;color:#2563eb;margin-top:4px">BD @Model.MonthlyRent.ToString("N2")</div>
          </div>
        </div>
      </div>
      @{ var amenityList = AmenitiesFormatter.Parse(Model.Amenities); }
      @if (amenityList.Count > 0)
      {
        <div style="margin-top:1rem;padding:1rem;background:var(--surface);border-radius:10px;border:1px solid var(--border)">
          <div style="font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);font-weight:700;margin-bottom:.6rem">Amenities</div>
          <div style="display:flex;flex-wrap:wrap;gap:6px">
            @foreach (var a in amenityList)
            {
              <span style="display:inline-block;background:var(--brand-bg);color:var(--brand);font-size:.74rem;font-weight:600;padding:3px 10px;border-radius:99px">@a</span>
            }
          </div>
        </div>
      }
    </div>
  </div>
</div>
