<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | PropManager</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --brand:   #111827;
            --brand2:  #374151;
            --brand3:  #6b7280;
            --brand-bg:#f3f4f6;
            --green:   #10b981;
            --amber:   #f59e0b;
            --red:     #ef4444;
            --navy:    #0f172a;
            --navy2:   #1e293b;
            --text:    #111827;
            --text2:   #374151;
            --muted:   #6b7280;
            --border:  #e5e7eb;
            --surface: #f9fafb;
            --white:   #ffffff;
            --shadow:  0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.04);
            --shadow-md: 0 4px 6px -1px rgba(0,0,0,.1), 0 2px 4px -2px rgba(0,0,0,.05);
            --shadow-lg: 0 10px 15px -3px rgba(0,0,0,.1), 0 4px 6px -4px rgba(0,0,0,.05);
            --radius:  10px;
            --radius-lg: 14px;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; font-size: 16px; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #f3f4f6;
            color: var(--text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
        }

        /* ════════════════════════════════════════
           NAVIGATION
        ════════════════════════════════════════ */
        .topbar {
            background: #111827;
            border-bottom: none;
            height: 56px;
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        .topbar-inner {
            height: 100%;
            display: flex;
            align-items: center;
            gap: 0;
            padding: 0 1.5rem;
            max-width: 1280px;
            margin: 0 auto;
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 9px;
            text-decoration: none;
            color: #fff;
            font-weight: 600;
            font-size: .9rem;
            letter-spacing: -.01em;
            padding-right: 1.25rem;
            border-right: 1px solid rgba(255,255,255,.1);
            margin-right: .5rem;
            flex-shrink: 0;
        }
        .brand-logo {
            width: 30px; height: 30px;
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.15);
            border-radius: 7px;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: .85rem;
        }
        .brand:hover { color: rgba(255,255,255,.8); }
        .nav-items {
            display: flex;
            align-items: center;
            gap: 1px;
            flex: 1;
            list-style: none;
            padding: 0;
        }
        .nav-items a {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 6px 11px;
            border-radius: 7px;
            font-size: .82rem;
            font-weight: 500;
            color: rgba(255,255,255,.55);
            text-decoration: none;
            transition: all .15s;
            white-space: nowrap;
        }
        .nav-items a:hover { color: #fff; background: rgba(255,255,255,.08); }
        .nav-items a.active { color: #fff; background: rgba(255,255,255,.13); }
        .nav-items a i { font-size: .85rem; }
        .topbar-right {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-left: auto;
            padding-left: 1rem;
            border-left: 1px solid rgba(255,255,255,.1);
        }
        .track-btn {
            display: flex;
            align-items: center;
            gap: 5px;
            padding: 5px 11px;
            border: 1px solid rgba(255,255,255,.18);
            border-radius: 7px;
            font-size: .8rem;
            color: rgba(255,255,255,.55);
            text-decoration: none;
            transition: all .15s;
            font-weight: 500;
        }
        .track-btn:hover { color: #fff; border-color: rgba(255,255,255,.4); }
        .avatar {
            width: 30px; height: 30px;
            background: rgba(255,255,255,.15);
            border: 1px solid rgba(255,255,255,.2);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: .7rem; font-weight: 700;
            flex-shrink: 0;
        }
        .user-name {
            font-size: .8rem;
            font-weight: 500;
            color: rgba(255,255,255,.6);
            max-width: 120px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .logout-btn {
            display: flex;
            align-items: center;
            gap: 5px;
            padding: 5px 11px;
            border: 1px solid rgba(255,255,255,.15);
            border-radius: 7px;
            background: none;
            font-size: .8rem;
            font-weight: 500;
            color: rgba(255,255,255,.5);
            cursor: pointer;
            transition: all .15s;
            font-family: inherit;
        }
        .logout-btn:hover { color: #fff; border-color: rgba(255,255,255,.35); background: rgba(255,255,255,.06); }
        .signin-btn {
            display: flex; align-items: center; gap: 5px;
            padding: 6px 15px;
            background: #fff;
            color: #111827;
            border-radius: 7px;
            font-size: .82rem;
            font-weight: 600;
            text-decoration: none;
            transition: background .15s;
        }
        .signin-btn:hover { background: #f3f4f6; color: #111827; }
        /* Notification bell */
        .notif-bell {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 33px;
            height: 33px;
            border-radius: 50%;
            border: 1px solid rgba(255,255,255,.18);
            background: none;
            color: rgba(255,255,255,.6);
            text-decoration: none;
            font-size: .95rem;
            transition: background .15s, border-color .15s;
        }
        .notif-bell:hover { background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.35); color: #fff; }
        .notif-badge {
            position: absolute;
            top: -3px;
            right: -3px;
            background: #ef4444;
            color: white;
            font-size: .55rem;
            font-weight: 700;
            min-width: 15px;
            height: 15px;
            border-radius: 99px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 3px;
            border: 2px solid #111827;
        }
        .register-btn {
            display: flex; align-items: center; gap: 5px;
            padding: 5px 12px;
            border: 1px solid rgba(255,255,255,.18);
            color: rgba(255,255,255,.6);
            border-radius: 7px;
            font-size: .82rem;
            font-weight: 500;
            text-decoration: none;
            transition: all .15s;
        }
        .register-btn:hover { border-color: rgba(255,255,255,.4); color: #fff; background: rgba(255,255,255,.06); }

        /* ════════════════════════════════════════
           PAGE STRUCTURE
        ════════════════════════════════════════ */
        main {
            flex: 1;
            padding: 2rem 0 4rem;
        }
        .page-wrap {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 1.5rem;
        }

        /* ════════════════════════════════════════
           PAGE HEADER
        ════════════════════════════════════════ */
        .ph {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 1.75rem;
        }
        .ph-left {}
        .ph-title {
            font-size: 1.2rem;
            font-weight: 600;
            letter-spacing: -.01em;
            color: var(--text);
            line-height: 1.2;
        }
        .ph-sub {
            font-size: .82rem;
            color: var(--muted);
            margin-top: 3px;
        }
        .breadcrumb {
            font-size: .78rem;
            margin: 4px 0 0;
            list-style: none;
            display: flex;
            align-items: center;
            gap: 0;
            padding: 0;
        }
        .breadcrumb-item { display: flex; align-items: center; }
        .breadcrumb-item + .breadcrumb-item::before {
            content: '/';
            color: #cbd5e1;
            margin: 0 6px;
        }
        .breadcrumb-item a { color: var(--brand); text-decoration: none; font-weight: 500; }
        .breadcrumb-item a:hover { text-decoration: underline; }
        .breadcrumb-item.active { color: var(--muted); }

        /* ════════════════════════════════════════
           KPI CARDS
        ════════════════════════════════════════ */
        .kpi {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1.1rem 1.25rem;
            display: flex;
            align-items: center;
            gap: .9rem;
            text-decoration: none;
            color: inherit;
        }
        .kpi-icon {
            width: 38px; height: 38px;
            border-radius: 8px;
            background: #f3f4f6;
            border: 1px solid #e5e7eb;
            display: flex; align-items: center; justify-content: center;
            font-size: .95rem;
            color: #6b7280;
            flex-shrink: 0;
        }
        .kpi-num { font-size: 1.45rem; font-weight: 700; letter-spacing: -.02em; line-height: 1; color: var(--text); }
        .kpi-label { font-size: .72rem; color: var(--muted); font-weight: 500; margin-top: 3px; text-transform: uppercase; letter-spacing: .04em; }

        /* ════════════════════════════════════════
           DATA TABLE
        ════════════════════════════════════════ */
        .dtable {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow);
        }
        .dtable table { margin: 0; width: 100%; border-collapse: collapse; }
        .dtable thead th {
            background: #f9fafb;
            color: #6b7280;
            font-size: .72rem;
            font-weight: 600;
            letter-spacing: .04em;
            text-transform: uppercase;
            padding: .75rem 1.1rem;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }
        .dtable thead th:first-child { padding-left: 1.4rem; }
        .dtable thead th:last-child  { padding-right: 1.4rem; }
        .dtable tbody tr {
            border-bottom: 1px solid #f1f5f9;
            transition: background .12s;
        }
        .dtable tbody tr:last-child { border-bottom: none; }
        .dtable tbody tr:hover { background: #f5f5f7; }
        .dtable tbody tr:hover td:first-child { box-shadow: inset 2px 0 0 var(--brand); }
        .row-warn { background: #fffcf0 !important; }
        .row-danger { background: #fff8f8 !important; }
        .dtable tbody td {
            padding: .9rem 1.1rem;
            font-size: .875rem;
            color: var(--text2);
            vertical-align: middle;
        }
        .dtable tbody td:first-child { padding-left: 1.4rem; }
        .dtable tbody td:last-child  { padding-right: 1.4rem; }

        /* ════════════════════════════════════════
           CARDS & FORMS
        ════════════════════════════════════════ */
        .card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow);
        }
        .form-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 2rem 2.25rem;
            box-shadow: var(--shadow);
        }
        .form-section {
            border-bottom: 1px solid var(--border);
            padding-bottom: 1.5rem;
            margin-bottom: 1.5rem;
        }
        .form-section:last-child { border-bottom: none; padding-bottom: 0; margin-bottom: 0; }
        .form-section-title {
            font-size: .8rem;
            font-weight: 500;
            color: var(--muted);
            margin-bottom: 1rem;
        }
        .form-control, .form-select {
            border: 1.5px solid var(--border);
            border-radius: 9px;
            font-size: .875rem;
            padding: .6rem .9rem;
            color: var(--text);
            background: var(--white);
            transition: border-color .15s, box-shadow .15s;
            font-family: inherit;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 3px rgba(99,102,241,.12);
            outline: none;
        }
        .form-control::placeholder { color: #94a3b8; }
        .form-label {
            font-size: .82rem;
            font-weight: 600;
            color: var(--text2);
            margin-bottom: .4rem;
            display: block;
        }
        .form-text { font-size: .76rem; color: var(--muted); margin-top: .3rem; }
        textarea.form-control { resize: vertical; min-height: 90px; }

        /* ════════════════════════════════════════
           BUTTONS
        ════════════════════════════════════════ */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-family: inherit;
            font-weight: 600;
            border-radius: 9px;
            transition: all .15s;
            cursor: pointer;
            font-size: .855rem;
        }
        .btn-primary {
            background: var(--brand);
            border: 1.5px solid var(--brand);
            color: white;
            padding: .55rem 1.15rem;
            box-shadow: 0 1px 4px rgba(99,102,241,.3);
        }
        .btn-primary:hover { background: var(--brand2); border-color: var(--brand2); color: white; }
        .btn-secondary {
            background: var(--white);
            border: 1.5px solid var(--border);
            color: var(--text2);
            padding: .55rem 1.15rem;
        }
        .btn-secondary:hover { border-color: var(--text2); color: var(--text); background: var(--surface); }
        .btn-danger {
            background: var(--red);
            border: 1.5px solid var(--red);
            color: white;
            padding: .55rem 1.15rem;
        }
        .btn-danger:hover { background: #dc2626; border-color: #dc2626; color: white; }
        .btn-outline-primary {
            background: transparent;
            border: 1.5px solid var(--brand);
            color: var(--brand);
            padding: .55rem 1.15rem;
        }
        .btn-outline-primary:hover { background: var(--brand); color: white; }
        .btn-outline-secondary {
            background: transparent;
            border: 1.5px solid var(--border);
            color: var(--muted);
            padding: .55rem 1.15rem;
        }
        .btn-outline-secondary:hover { border-color: var(--text2); color: var(--text2); }
        .btn-outline-danger {
            background: transparent;
            border: 1.5px solid var(--red);
            color: var(--red);
            padding: .55rem 1.15rem;
        }
        .btn-outline-danger:hover { background: var(--red); color: white; }
        .btn-sm { padding: .35rem .8rem; font-size: .78rem; }
        .btn-xs { padding: .22rem .6rem; font-size: .73rem; }

        /* ════════════════════════════════════════
           BADGES / STATUS PILLS
        ════════════════════════════════════════ */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: .28em .75em;
            border-radius: 20px;
            font-size: .72rem;
            font-weight: 600;
            letter-spacing: .02em;
        }
        .badge::before {
            content: '';
            width: 5px; height: 5px;
            border-radius: 50%;
            background: currentColor;
            opacity: .6;
        }
        .s-active     { background: #d1fae5; color: #065f46; }
        .s-pending    { background: #fef3c7; color: #92400e; }
        .s-screening  { background: #dbeafe; color: #1e40af; }
        .s-rejected   { background: #fee2e2; color: #991b1b; }
        .s-terminated { background: #f1f5f9; color: #475569; }
        .s-overdue    { background: #fee2e2; color: #991b1b; }
        .s-paid       { background: #d1fae5; color: #065f46; }
        .s-partial    { background: #fef3c7; color: #92400e; }
        .s-submitted  { background: #fef3c7; color: #92400e; }
        .s-assigned   { background: #dbeafe; color: #1e40af; }
        .s-inprogress { background: #e0f2fe; color: #075985; }
        .s-resolved   { background: #d1fae5; color: #065f46; }
        .s-closed     { background: #f1f5f9; color: #475569; }
        .s-available  { background: #d1fae5; color: #065f46; }
        .s-occupied   { background: #dbeafe; color: #1e40af; }

        /* ════════════════════════════════════════
           ALERTS / TOASTS
        ════════════════════════════════════════ */
        .alert {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: .8rem 1.1rem;
            border-radius: var(--radius);
            font-size: .875rem;
            font-weight: 500;
            border: none;
        }
        .alert-success { background: #d1fae5; color: #065f46; }
        .alert-danger  { background: #fee2e2; color: #991b1b; }
        .alert-info    { background: #dbeafe; color: #1e40af; }
        .alert-warning { background: #fef3c7; color: #92400e; }
        .alert i { font-size: 1rem; flex-shrink: 0; }

        /* ════════════════════════════════════════
           EMPTY STATES
        ════════════════════════════════════════ */
        .empty-state {
            text-align: center;
            padding: 3.5rem 2rem;
        }
        .empty-icon {
            font-size: 1.75rem;
            color: #cbd5e1;
            margin-bottom: 1rem;
            display: block;
        }
        .empty-title { font-size: .9rem; font-weight: 600; color: var(--text2); margin-bottom: .35rem; }
        .empty-sub   { font-size: .82rem; color: var(--muted); max-width: 300px; margin: 0 auto .5rem; line-height: 1.55; }

        /* ════════════════════════════════════════
           ACTION LINKS in table
        ════════════════════════════════════════ */
        .tbl-actions {
            display: flex;
            align-items: center;
            gap: 4px;
            justify-content: flex-end;
            flex-wrap: wrap;
        }
        .tbl-link {
            display: inline-flex; align-items: center; gap: 3px;
            padding: 4px 9px;
            border-radius: 6px;
            font-size: .76rem;
            font-weight: 600;
            text-decoration: none;
            transition: all .12s;
            white-space: nowrap;
        }
        .tbl-link-view    { color: var(--brand); background: var(--brand-bg); }
        .tbl-link-view:hover { background: #c7d2fe; color: var(--brand2); }
        .tbl-link-edit    { color: var(--muted); background: var(--surface); border: 1px solid var(--border); }
        .tbl-link-edit:hover { color: var(--text); background: #e2e8f0; }
        .tbl-link-danger  { color: var(--red); background: #fef2f2; }
        .tbl-link-danger:hover { background: #fee2e2; }

        /* ════════════════════════════════════════
           INLINE FORM BUTTONS (lifecycle actions)
        ════════════════════════════════════════ */
        .tbl-btn {
            display: inline-flex; align-items: center; gap: 3px;
            padding: 4px 9px;
            border-radius: 6px;
            font-size: .76rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: all .12s;
            font-family: inherit;
            white-space: nowrap;
        }
        .tbl-btn-approve { color: #065f46; background: #d1fae5; }
        .tbl-btn-approve:hover { background: #a7f3d0; }
        .tbl-btn-screen  { color: #1e40af; background: #dbeafe; }
        .tbl-btn-screen:hover { background: #bfdbfe; }
        .tbl-btn-reject  { color: #991b1b; background: #fee2e2; }
        .tbl-btn-reject:hover { background: #fecaca; }
        .tbl-btn-renew   { color: #075985; background: #e0f2fe; }
        .tbl-btn-renew:hover { background: #bae6fd; }
        .tbl-btn-term    { color: #92400e; background: #fef3c7; }
        .tbl-btn-term:hover { background: #fde68a; }

        /* ════════════════════════════════════════
           MODALS
        ════════════════════════════════════════ */
        .modal-content {
            border-radius: var(--radius-lg);
            border: none;
            box-shadow: 0 25px 50px rgba(0,0,0,.2);
        }
        .modal-header {
            border-bottom: 1px solid var(--border);
            padding: 1.25rem 1.5rem;
        }
        .modal-title { font-size: 1rem; font-weight: 700; }
        .modal-body  { padding: 1.5rem; }
        .modal-footer {
            border-top: 1px solid var(--border);
            padding: 1rem 1.5rem;
            gap: .5rem;
        }

        /* ════════════════════════════════════════
           FOOTER
        ════════════════════════════════════════ */
        .footer {
            background: var(--white);
            border-top: 1px solid var(--border);
            padding: 1.25rem 1.5rem;
            font-size: .78rem;
            color: var(--muted);
            margin-top: auto;
        }
        .footer a { color: var(--muted); text-decoration: none; }
        .footer a:hover { color: var(--brand); }

        /* ════════════════════════════════════════
           UTILITIES
        ════════════════════════════════════════ */
        .fw-600 { font-weight: 600; }
        .fw-700 { font-weight: 700; }
        .text-brand { color: var(--brand); }
        .mono { font-family: 'JetBrains Mono', monospace; }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<body>

<nav class="topbar">
    <div class="topbar-inner">
        <a class="brand" asp-controller="Home" asp-action="Index">
            <span class="brand-logo"><i class="bi bi-buildings-fill"></i></span>
            PropManager
        </a>

        <ul class="nav-items">
            <li><a asp-controller="Home" asp-action="Index"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a></li>
            @if (User.Identity?.IsAuthenticated == true)
            {
                @if (User.IsInRole("PropertyManager"))
                {
                    <li><a asp-controller="Buildings" asp-action="Index"><i class="bi bi-building"></i> Buildings</a></li>
                    <li><a asp-controller="Units" asp-action="Index"><i class="bi bi-door-closed"></i> Units</a></li>
                    <li><a asp-controller="Staff" asp-action="Index"><i class="bi bi-people"></i> Staff</a></li>
                }
                <li><a asp-controller="Leases" asp-action="Index"><i class="bi bi-file-earmark-text"></i> Leases</a></li>
                <li><a asp-controller="Payments" asp-action="Index"><i class="bi bi-credit-card"></i> Payments</a></li>
                @if (User.IsInRole("PropertyManager") || User.IsInRole("MaintenanceStaff"))
                {
                    <li><a asp-controller="Maintenance" asp-action="Board"><i class="bi bi-kanban"></i> Live Board</a></li>
                }
                @if (User.IsInRole("Tenant"))
                {
                    <li><a asp-controller="Leases" asp-action="Browse"><i class="bi bi-door-open"></i> Browse Units</a></li>
                    <li><a asp-controller="Maintenance" asp-action="Index"><i class="bi bi-tools"></i> My Requests</a></li>
                }
            }
        </ul>

        <div class="topbar-right">
            <a class="track-btn" asp-controller="PublicLookup" asp-action="Index">
                <i class="bi bi-search"></i> Track
            </a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <!-- Notification bell with live badge -->
                <a asp-controller="Notifications" asp-action="Index" class="notif-bell" id="notifBell" title="Notifications">
                    <i class="bi bi-bell"></i>
                    <span class="notif-badge" id="notifBadge" style="display:none">0</span>
                </a>
                <div class="avatar">@(User.Identity.Name?.Substring(0,1).ToUpper())</div>
                <span class="user-name d-none d-md-block">@User.Identity.Name</span>
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-btn"><i class="bi bi-box-arrow-right"></i> <span class="d-none d-md-inline">Sign out</span></button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Register" class="register-btn">Register</a>
                <a asp-controller="Account" asp-action="Login" class="signin-btn">Sign in</a>
            }
        </div>
    </div>
</nav>

<main role="main">
    <div class="page-wrap">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success mt-3 mb-0">
                <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mt-3 mb-0">
                <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
            </div>
        }
    </div>
    @RenderBody()
</main>


<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
<script>
// Auto-mark active nav link
document.querySelectorAll('.nav-items a').forEach(link => {
    if (link.href === window.location.href ||
        (link.href !== window.location.origin + '/' && window.location.pathname.startsWith(new URL(link.href).pathname))) {
        link.classList.add('active');
    }
});
// Auto-dismiss alerts after 5s
setTimeout(() => {
    document.querySelectorAll('.alert').forEach(a => {
        a.style.transition = 'opacity .5s';
        a.style.opacity = '0';
        setTimeout(() => a.remove(), 500);
    });
}, 5000);
</script>
@await RenderSectionAsync("Scripts", required: false)
@if (User.Identity?.IsAuthenticated == true)
{
<script>
// Poll for unread notification count every 30 seconds and update the bell badge
(function () {
    var badge = document.getElementById('notifBadge');
    if (!badge) return;
    function poll() {
        fetch('/Notifications/UnreadCount')
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (d.count > 0) {
                    badge.textContent = d.count > 99 ? '99+' : d.count;
                    badge.style.display = 'flex';
                } else {
                    badge.style.display = 'none';
                }
            })
            .catch(function(){/* ignore network errors during polling */});
    }
    poll();
    setInterval(poll, 30000);
}());
</script>
}
</body>
</html>
