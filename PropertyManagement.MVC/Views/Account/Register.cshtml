@model PropertyManagement.MVC.Models.RegisterViewModel
@{ ViewData["Title"] = "Register"; Layout = "_Layout"; }

<div style="min-height:calc(100vh - 61px);display:flex;align-items:center;justify-content:center;padding:3rem 1rem;background:var(--surface)">
  <div style="width:100%;max-width:480px">

    <div style="margin-bottom:2rem">
      <div style="font-size:1.1rem;font-weight:600;color:var(--text);margin-bottom:.3rem">Create a tenant account</div>
      <div style="font-size:.84rem;color:var(--muted)">Register to apply for a unit and manage your lease</div>
    </div>

    <div class="form-card" style="padding:1.75rem">
      @if (!ViewData.ModelState.IsValid)
      {
        <div asp-validation-summary="All" class="alert alert-danger mb-4"></div>
      }
      <form asp-action="Register" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-3 mb-3">
          <div class="col-12">
            <label asp-for="Email" class="form-label">Email <span style="color:var(--red)">*</span></label>
            <input asp-for="Email" class="form-control" type="email" placeholder="you@example.com" autocomplete="email" />
            <span asp-validation-for="Email" class="text-danger" style="font-size:.76rem"></span>
          </div>
          <div class="col-md-6">
            <label asp-for="Password" class="form-label">Password <span style="color:var(--red)">*</span></label>
            <input asp-for="Password" class="form-control" type="password" placeholder="Min. 6 chars" />
            <span asp-validation-for="Password" class="text-danger" style="font-size:.76rem"></span>
          </div>
          <div class="col-md-6">
            <label asp-for="ConfirmPassword" class="form-label">Confirm password <span style="color:var(--red)">*</span></label>
            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Repeat password" />
            <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:.76rem"></span>
          </div>
          <div class="col-md-6">
            <label asp-for="PhoneNumber" class="form-label">Phone number</label>
            <input asp-for="PhoneNumber" class="form-control" placeholder="+973 XXXX XXXX" />
          </div>
          <div class="col-md-6">
            <label asp-for="CPR" class="form-label">CPR number</label>
            <input asp-for="CPR" class="form-control" placeholder="e.g. 880112345" />
          </div>
          <div class="col-12">
            <label asp-for="Occupation" class="form-label">Occupation</label>
            <input asp-for="Occupation" class="form-control" placeholder="e.g. Software Engineer" />
          </div>
          <div class="col-12">
            <label asp-for="EmergencyContact" class="form-label">Emergency contact</label>
            <input asp-for="EmergencyContact" class="form-control" placeholder="Name, +973 XXXX XXXX" />
          </div>
        </div>
        <button type="submit" class="btn btn-primary w-100" style="justify-content:center;padding:.65rem">
          Create account
        </button>
      </form>
      <div style="text-align:center;margin-top:1.25rem;font-size:.83rem;color:var(--muted)">
        Already have an account? <a asp-action="Login" style="color:var(--brand);font-weight:500;text-decoration:none">Sign in</a>
      </div>
    </div>

  </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
