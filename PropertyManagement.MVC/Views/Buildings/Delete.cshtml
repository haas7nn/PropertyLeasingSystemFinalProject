@model PropertyManagement.MVC.Models.BuildingViewModel

<div class="container mt-4">
    <h2 class="text-danger">Delete Building</h2>
    <p>Are you sure you want to delete this building?</p>
    <hr />

    <div>
        <h5>@Model.Name</h5>
        <p class="text-muted">@Model.Address</p>
    </div>

    <form asp-action="Delete" method="post" class="mt-4">
        <input type="hidden" asp-for="BuildingId" />
        <div class="d-flex gap-3 align-items-center">
            <button type="submit" class="btn btn-link p-0 text-danger text-decoration-none">Confirm Delete</button>
            <a asp-action="Index" class="text-dark text-decoration-none">Cancel</a>
        </div>
    </form>
</div>