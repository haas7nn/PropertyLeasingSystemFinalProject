@model PropertyManagement.MVC.Models.BuildingViewModel
@{ ViewData["Title"] = "Building Details"; }

<div class="page-wrap" style="padding-top:2rem;max-width:700px">
  <div class="ph">
    <div>
      <div class="ph-title">@Model.Name</div>
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Buildings</a></li>
        <li class="breadcrumb-item active">Details</li>
      </ol>
    </div>
    <div style="display:flex;gap:8px">
      <a asp-action="Edit" asp-route-id="@Model.BuildingId" class="btn btn-secondary btn-sm"><i class="bi bi-pencil"></i> Edit</a>
      <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
  </div>

  <div class="card p-0" style="overflow:hidden">
    <div style="background:var(--navy);padding:1.5rem;display:flex;align-items:center;gap:1rem">
      <div style="width:48px;height:48px;background:rgba(99,102,241,.35);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:#fff">
        <i class="bi bi-building"></i>
      </div>
      <div>
        <div style="color:#fff;font-size:1.1rem;font-weight:700">@Model.Name</div>
        <div style="color:rgba(255,255,255,.45);font-size:.8rem">@Model.Address</div>
      </div>
    </div>
    <div class="p-4">
      <div class="row g-3">
        <div class="col-md-6">
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1rem">
            <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);font-weight:700">Location</div>
            <div style="font-size:.95rem;font-weight:600;margin-top:4px">@(Model.Location ?? "")</div>
          </div>
        </div>
        <div class="col-md-6">
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1rem">
            <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);font-weight:700">Total Units</div>
            <div style="font-size:.95rem;font-weight:600;margin-top:4px">@Model.TotalUnits</div>
          </div>
        </div>
        <div class="col-md-6">
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1rem">
            <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);font-weight:700">Occupied</div>
            <div style="font-size:.95rem;font-weight:600;color:#16a34a;margin-top:4px">@Model.OccupiedUnits</div>
          </div>
        </div>
        <div class="col-md-6">
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1rem">
            <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);font-weight:700">Available</div>
            <div style="font-size:.95rem;font-weight:600;color:#2563eb;margin-top:4px">@Model.AvailableUnits</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
