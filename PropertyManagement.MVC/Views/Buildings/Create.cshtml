@model PropertyManagement.MVC.Models.BuildingViewModel

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Create Building</h2>
        <a asp-action="Index" class="text-dark text-decoration-none">Back to List</a>
    </div>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Name</label>
                    <input asp-for="Name" class="form-control border-dark-subtle" placeholder="Enter building name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label">Address</label>
                    <input asp-for="Address" class="form-control border-dark-subtle" placeholder="Street address" />
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Location" class="form-label">Location</label>
                    <input asp-for="Location" class="form-control border-dark-subtle" placeholder="City/Area" />
                    <span asp-validation-for="Location" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="TotalUnits" class="form-label">Total Units</label>
                    <input asp-for="TotalUnits" type="number" class="form-control border-dark-subtle" />
                    <span asp-validation-for="TotalUnits" class="text-danger small"></span>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-outline-dark px-4">Create Building</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}