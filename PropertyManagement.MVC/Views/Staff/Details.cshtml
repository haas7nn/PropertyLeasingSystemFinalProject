@model PropertyManagement.MVC.Models.EditStaffViewModel
@{ ViewData["Title"] = "Staff Details"; }

<div class="page-wrap" style="padding-top:2rem">
  <div class="ph">
    <div>
      <div class="ph-title">Staff Profile</div>
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Staff</a></li>
        <li class="breadcrumb-item active">@Model.Email</li>
      </ol>
    </div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
  </div>

  <div class="row g-4">
    <div class="col-lg-4">
      <div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:1.75rem;text-align:center">
        <div style="width:64px;height:64px;border-radius:50%;background:var(--brand-bg);color:var(--brand);display:flex;align-items:center;justify-content:center;font-size:1.6rem;font-weight:700;margin:0 auto 1rem">
          @Model.Email[0].ToString().ToUpper()
        </div>
        <div style="font-weight:700;font-size:1rem;margin-bottom:.25rem">@Model.Email</div>
        @if (!string.IsNullOrEmpty(Model.PhoneNumber))
        {
          <div style="font-size:.82rem;color:var(--muted)">@Model.PhoneNumber</div>
        }
        @{
          var avBg = Model.AvailabilityStatus == "Available" ? "#f0fdf4" : Model.AvailabilityStatus == "Busy" ? "#fef3c7" : "#f1f5f9";
          var avColor = Model.AvailabilityStatus == "Available" ? "#16a34a" : Model.AvailabilityStatus == "Busy" ? "#d97706" : "#64748b";
        }
        <span style="display:inline-block;background:@avBg;color:@avColor;font-size:.72rem;font-weight:700;padding:3px 12px;border-radius:99px;margin-top:.75rem">@Model.AvailabilityStatus</span>

        @if (!string.IsNullOrEmpty(Model.Skills))
        {
          <div style="margin-top:1.25rem;text-align:left">
            <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);margin-bottom:.5rem">Skills</div>
            @foreach (var skill in Model.Skills.Split(',', StringSplitOptions.TrimEntries))
            {
              <span style="display:inline-block;background:var(--brand-bg);color:var(--brand);font-size:.7rem;font-weight:700;padding:3px 9px;border-radius:20px;margin:2px">@skill</span>
            }
          </div>
        }
      </div>
    </div>

    <div class="col-lg-8">
      <div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:1.75rem">
        <div style="font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:1rem">Assigned Requests</div>
        @{
          var assigned = ViewBag.AssignedRequests as IEnumerable<PropertyManagement.MVC.Models.MaintenanceRequestViewModel>;
        }
        @if (assigned == null || !assigned.Any())
        {
          <div style="color:var(--muted);font-size:.85rem;text-align:center;padding:2rem 0">No requests assigned to this staff member.</div>
        }
        else
        {
          <table class="table table-sm" style="font-size:.82rem">
            <thead>
              <tr>
                <th>Ticket</th>
                <th>Category</th>
                <th>Priority</th>
                <th>Status</th>
                <th>Unit</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var r in assigned)
              {
                <tr>
                  <td style="font-family:'JetBrains Mono',monospace;font-size:.75rem;color:var(--brand)">@r.TicketNumber</td>
                  <td>@r.Category</td>
                  <td>@r.Priority</td>
                  <td><span class="badge @(r.Status switch{"Submitted"=>"s-pending","Assigned"=>"s-assigned","InProgress"=>"s-inprogress","Resolved"=>"s-resolved","Closed"=>"s-closed",_=>"s-pending"})">@r.Status</span></td>
                  <td>@r.UnitNumber</td>
                  <td>@r.SubmittedDate.ToString("dd MMM yy")</td>
                </tr>
              }
            </tbody>
          </table>
        }
      </div>
    </div>
  </div>
</div>
