@model PropertyManagement.MVC.Models.LeaseViewModel

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-baseline">
        <h3>Lease Details - @Model.LeaseId</h3>
        <span class="text-muted text-uppercase small">@Model.Status</span>
    </div>
    <hr />

    <div class="row mb-4">
        <div class="col-sm-6">
            <h6 class="text-muted fw-bold">Unit Information</h6>
            <p><strong>Building:</strong> @Model.BuildingName</p>
            <p><strong>Unit Number:</strong> @Model.UnitNumber</p>
            <p><strong>Tenant:</strong> @Model.TenantEmail</p>
        </div>
        <div class="col-sm-6">
            <h6 class="text-muted fw-bold">Financials & Dates</h6>
            <p><strong>Period:</strong> @Model.StartDate.ToShortDateString() - @Model.EndDate.ToShortDateString()</p>
            <p><strong>Monthly Rent:</strong> @Model.MonthlyRent.ToString("C")</p>
            <p><strong>Security Deposit:</strong> @Model.SecurityDeposit.ToString("C")</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ScreeningNotes))
    {
        <div class="mb-4">
            <h6 class="text-muted fw-bold">Screening Notes</h6>
            <p class="border-start ps-3 py-1">@Model.ScreeningNotes</p>
        </div>
    }

    <div class="d-flex gap-3 align-items-center pt-3 border-top">
        <a asp-action="Edit" asp-route-id="@Model.LeaseId" class="text-dark text-decoration-none">Edit</a>
        <a asp-action="Index" class="text-dark text-decoration-none">Back to List</a>

        @if (Model.Status == "Active")
        {
            <button type="button" class="btn btn-link p-0 text-dark text-decoration-none ms-auto" data-bs-toggle="modal" data-bs-target="#terminateModal">
                Terminate Lease
            </button>
        }
    </div>
</div>

<div class="modal fade" id="terminateModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="Terminate" asp-route-id="@Model.LeaseId" method="post">
            <div class="modal-content border-dark">
                <div class="modal-header border-0">
                    <h5 class="modal-title">Confirm Termination</h5>
                </div>
                <div class="modal-body">
                    <p>Reason for termination:</p>
                    <textarea name="reason" class="form-control border-dark-subtle" required></textarea>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-link text-dark text-decoration-none" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-outline-danger">Confirm Termination</button>
                </div>
            </div>
        </form>
    </div>
</div>