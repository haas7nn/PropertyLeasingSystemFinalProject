@model PropertyManagement.MVC.Models.LeaseViewModel
@{
    ViewData["Title"] = "New Lease Application";
    var units   = ViewBag.AvailableUnits as List<PropertyManagement.API.Models.Unit>   ?? new();
    var tenants = ViewBag.Tenants        as List<PropertyManagement.API.Models.Tenant> ?? new();
}

<div class="page-wrap" style="padding-top:2rem;max-width:820px">
  <div class="ph">
    <div>
      <div class="ph-title">New Lease Application</div>
      <ol class="breadcrumb"><li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li><li class="breadcrumb-item"><a asp-action="Index">Leases</a></li><li class="breadcrumb-item active">New</li></ol>
    </div>
  </div>

  <div class="form-card">
    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
    }

    <form asp-action="Create" method="post">
      @Html.AntiForgeryToken()

      <!-- Unit Selection -->
      <div class="form-section">
        <div class="form-section-title">Unit Selection</div>
        <div class="mb-3">
          <label asp-for="UnitId" class="form-label">Available Unit <span style="color:var(--red)">*</span></label>
          <select asp-for="UnitId" class="form-select" id="unitSelect">
            <option value="">Select an available unit</option>
            @foreach (var u in units)
            {
              <option value="@u.UnitId" data-rent="@u.MonthlyRent" data-deposit="@u.MonthlyRent">
                @(u.Building?.Name), Unit @u.UnitNumber
                @(u.Bedrooms.HasValue ? $"({u.Type}, {u.Bedrooms} bd)" : $"({u.Type})")
                BD @u.MonthlyRent.ToString("N2")/mo
              </option>
            }
          </select>
          <span asp-validation-for="UnitId" class="text-danger" style="font-size:.76rem"></span>
          @if (!units.Any())
          {
            <div class="form-text" style="color:var(--red)"><i class="bi bi-exclamation-triangle me-1"></i>No available units. Add units or terminate an active lease first.</div>
          }
        </div>
      </div>

      <!-- Tenant -->
      <div class="form-section">
        <div class="form-section-title">Tenant</div>
        <div class="mb-3">
          <label asp-for="TenantId" class="form-label">Tenant <span style="color:var(--red)">*</span></label>
          <select asp-for="TenantId" class="form-select">
            <option value="">Select a registered tenant</option>
            @foreach (var t in tenants)
            {
              <option value="@t.Id">@t.Email @(string.IsNullOrEmpty(t.Occupation) ? "" : $"({t.Occupation})")</option>
            }
          </select>
          <span asp-validation-for="TenantId" class="text-danger" style="font-size:.76rem"></span>
          @if (!tenants.Any())
          {
            <div class="form-text" style="color:var(--red)"><i class="bi bi-exclamation-triangle me-1"></i>No tenants registered. Ask the tenant to register an account first.</div>
          }
        </div>
      </div>

      <!-- Lease Terms -->
      <div class="form-section">
        <div class="form-section-title">Lease Terms</div>
        <div class="row g-3">
          <div class="col-md-6">
            <label asp-for="StartDate" class="form-label">Start Date <span style="color:var(--red)">*</span></label>
            <input asp-for="StartDate" type="date" class="form-control" />
            <span asp-validation-for="StartDate" class="text-danger" style="font-size:.76rem"></span>
          </div>
          <div class="col-md-6">
            <label asp-for="EndDate" class="form-label">End Date <span style="color:var(--red)">*</span></label>
            <input asp-for="EndDate" type="date" class="form-control" />
            <span asp-validation-for="EndDate" class="text-danger" style="font-size:.76rem"></span>
          </div>
          <div class="col-md-6">
            <label asp-for="MonthlyRent" class="form-label">Monthly Rent (BD) <span style="color:var(--red)">*</span></label>
            <div style="position:relative">
              <span style="position:absolute;left:.9rem;top:50%;transform:translateY(-50%);color:var(--muted);font-size:.82rem;font-weight:600">BD</span>
              <input asp-for="MonthlyRent" type="number" step="0.01" class="form-control" id="rentField" style="padding-left:2.5rem" />
            </div>
            <span asp-validation-for="MonthlyRent" class="text-danger" style="font-size:.76rem"></span>
          </div>
          <div class="col-md-6">
            <label asp-for="SecurityDeposit" class="form-label">Security Deposit (BD) <span style="color:var(--red)">*</span></label>
            <div style="position:relative">
              <span style="position:absolute;left:.9rem;top:50%;transform:translateY(-50%);color:var(--muted);font-size:.82rem;font-weight:600">BD</span>
              <input asp-for="SecurityDeposit" type="number" step="0.01" class="form-control" id="depositField" style="padding-left:2.5rem" />
            </div>
            <span asp-validation-for="SecurityDeposit" class="text-danger" style="font-size:.76rem"></span>
          </div>
        </div>
      </div>

      <!-- Notes -->
      <div class="form-section">
        <div class="form-section-title">Notes</div>
        <div>
          <label asp-for="ScreeningNotes" class="form-label">Screening Notes <span style="color:var(--muted);font-weight:400">(optional)</span></label>
          <textarea asp-for="ScreeningNotes" class="form-control" rows="3" placeholder="Employment verification, references, CPR check results..."></textarea>
        </div>
      </div>

      <div style="display:flex;gap:10px">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check2-circle"></i> Create Application</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>

@section Scripts {
@{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
<script>
document.getElementById('unitSelect')?.addEventListener('change', function() {
    const opt = this.selectedOptions[0];
    if (opt && opt.dataset.rent) {
        document.getElementById('rentField').value    = opt.dataset.rent;
        document.getElementById('depositField').value = opt.dataset.deposit || opt.dataset.rent;
    }
});
</script>
}
