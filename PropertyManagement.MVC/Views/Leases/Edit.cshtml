@model PropertyManagement.MVC.Models.LeaseViewModel
@{ ViewData["Title"] = "Edit Lease"; }
<div class="page-wrap" style="padding-top:2rem;max-width:680px">
  <div class="ph">
    <div><div class="ph-title">Edit Lease #@Model.LeaseId</div>
    <ol class="breadcrumb"><li class="breadcrumb-item"><a asp-action="Index">Leases</a></li><li class="breadcrumb-item active">Edit</li></ol></div>
  </div>
  <div class="form-card">
    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
    }
    <div style="background:var(--surface);border-radius:10px;padding:.9rem 1rem;margin-bottom:1.5rem;font-size:.84rem;color:var(--muted)">
      <i class="bi bi-info-circle me-1"></i> Only financial fields and notes are editable. Lifecycle changes (Approve, Terminate, Renew) are done from the Leases list.
    </div>
    <form asp-action="Edit" asp-route-id="@Model.LeaseId" method="post">
      @Html.AntiForgeryToken()
      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <label asp-for="StartDate" class="form-label">Start Date</label>
          <input asp-for="StartDate" type="date" class="form-control" />
        </div>
        <div class="col-md-6">
          <label asp-for="EndDate" class="form-label">End Date</label>
          <input asp-for="EndDate" type="date" class="form-control" />
        </div>
        <div class="col-md-6">
          <label asp-for="MonthlyRent" class="form-label">Monthly Rent (BD)</label>
          <div style="position:relative">
            <span style="position:absolute;left:.9rem;top:50%;transform:translateY(-50%);color:var(--muted);font-size:.82rem;font-weight:600">BD</span>
            <input asp-for="MonthlyRent" type="number" step="0.01" class="form-control" style="padding-left:2.5rem" />
          </div>
        </div>
        <div class="col-md-6">
          <label asp-for="SecurityDeposit" class="form-label">Security Deposit (BD)</label>
          <div style="position:relative">
            <span style="position:absolute;left:.9rem;top:50%;transform:translateY(-50%);color:var(--muted);font-size:.82rem;font-weight:600">BD</span>
            <input asp-for="SecurityDeposit" type="number" step="0.01" class="form-control" style="padding-left:2.5rem" />
          </div>
        </div>
        <div class="col-12">
          <label asp-for="ScreeningNotes" class="form-label">Screening Notes</label>
          <textarea asp-for="ScreeningNotes" class="form-control" rows="3"></textarea>
        </div>
      </div>
      <div style="display:flex;gap:10px">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
