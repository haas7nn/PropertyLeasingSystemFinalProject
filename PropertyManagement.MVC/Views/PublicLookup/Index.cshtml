@{
    ViewData["Title"] = "Track Maintenance Request";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    /* Modern minimalist styling */
    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
    }

    .track-container {
        max-width: 450px;
        width: 100%;
        margin: auto;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.95);
        border: none;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }

    .brand-header {
        background: #212529; /* Deep dark professional header */
        padding: 40px 20px;
        text-align: center;
        color: white;
    }

        .brand-header i {
            font-size: 2.5rem;
            margin-bottom: 10px;
            color: #0d6efd;
        }

    .form-floating > .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
    }

    .btn-track {
        background: #0d6efd;
        border: none;
        padding: 12px;
        border-radius: 12px;
        font-weight: 600;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
    }

        .btn-track:hover {
            background: #0b5ed7;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(13, 110, 253, 0.3);
        }

    .input-group-text {
        background-color: transparent;
        border-right: none;
        color: #6c757d;
    }

    .form-control {
        border-left: none;
    }

        .form-control:focus + .input-group-text {
            border-color: #0d6efd;
        }
</style>

<div class="container">
    <div class="track-container">
        <div class="card glass-card">
            <div class="brand-header">
                <i class="bi bi-search-heart"></i>
                <h3 class="fw-bold mb-0">Maintenance Tracker</h3>
                <p class="small opacity-75 mt-2 mb-0">Enter your details to see live updates</p>
            </div>

            <div class="card-body p-4 p-md-5">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger border-0 shadow-sm d-flex align-items-center mb-4" role="alert">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        <div class="small">@ViewBag.Error</div>
                    </div>
                }

                <form method="post" asp-action="Search">
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-uppercase text-muted">Ticket ID</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-ticket-perforated"></i></span>
                            <input type="text"
                                   class="form-control form-control-lg"
                                   id="ticketNumber"
                                   name="ticketNumber"
                                   placeholder="MNT-000000"
                                   required />
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="form-label small fw-bold text-uppercase text-muted">Phone Number</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-phone"></i></span>
                            <input type="tel"
                                   class="form-control form-control-lg"
                                   id="phoneNumber"
                                   name="phoneNumber"
                                   placeholder="Registered number"
                                   required />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-track w-100 shadow-sm">
                        Find My Request <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>