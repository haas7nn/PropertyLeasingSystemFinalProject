@model PropertyManagement.MVC.Models.MaintenanceLookupDto

@{
    ViewData["Title"] = "Request Details";

    var statusColor = Model.Status switch
    {
        "Submitted" => "warning",
        "Assigned" => "info",
        "InProgress" => "primary",
        "Resolved" => "success",
        "Closed" => "secondary",
        _ => "secondary"
    };

    var priorityColor = Model.Priority switch
    {
        "Urgent" => "danger",
        "High" => "warning",
        "Medium" => "info",
        "Low" => "secondary",
        _ => "secondary"
    };

    var statusIcon = Model.Status switch
    {
        "Submitted" => "bi-clock-history",
        "Assigned" => "bi-person-check",
        "InProgress" => "bi-gear",
        "Resolved" => "bi-check-circle",
        "Closed" => "bi-check2-all",
        _ => "bi-question-circle"
    };

    var progressPercent = Model.Status switch
    {
        "Submitted" => 20,
        "Assigned" => 40,
        "InProgress" => 60,
        "Resolved" => 80,
        "Closed" => 100,
        _ => 0
    };
}

<div class="page-header text-center">
    <div class="container">
        <h1 class="display-6 fw-bold mb-3">
            <i class="bi bi-check-circle"></i> Request Found
        </h1>
        <p class="lead mb-0">Here are the details of your maintenance request</p>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Header Card -->
            <div class="card mb-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="card-body text-white p-4">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <h6 class="text-white-50 mb-2">Ticket Number</h6>
                            <h2 class="fw-bold mb-0">@Model.TicketNumber</h2>
                        </div>
                        <div class="col-md-6 text-md-end mt-3 mt-md-0">
                            <h6 class="text-white-50 mb-2">Current Status</h6>
                            <h3>
                                <span class="badge bg-light text-dark">
                                    <i class="bi @statusIcon"></i> @Model.Status
                                </span>
                            </h3>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Progress Timeline -->
            <div class="card mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-arrow-repeat"></i> Request Progress
                    </h5>
                </div>
                <div class="card-body">
                    <div class="progress" style="height: 35px; border-radius: 20px;">
                        <div class="progress-bar bg-@statusColor progress-bar-striped progress-bar-animated"
                             role="progressbar"
                             style="width: @progressPercent%"
                             aria-valuenow="@progressPercent"
                             aria-valuemin="0"
                             aria-valuemax="100">
                            <strong>@progressPercent%</strong>
                        </div>
                    </div>
                    <div class="mt-3 text-center">
                        <small class="text-muted">
                            <strong>@Model.Status</strong> -
                            @if (Model.Status == "Submitted")
                            {
                                <span>Your request has been received and is awaiting assignment</span>
                            }
                            else if (Model.Status == "Assigned")
                            {
                                <span>A technician has been assigned to your request</span>
                            }
                            else if (Model.Status == "InProgress")
                            {
                                <span>Work is currently being performed</span>
                            }
                            else if (Model.Status == "Resolved")
                            {
                                <span>The issue has been resolved and is awaiting closure</span>
                            }
                            else if (Model.Status == "Closed")
                            {
                                <span>This request has been completed</span>
                            }
                        </small>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <!-- Main Details -->
                <div class="col-lg-8">
                    <div class="card h-100">
                        <div class="card-header bg-white">
                            <h5 class="mb-0 fw-bold">
                                <i class="bi bi-file-text"></i> Request Details
                            </h5>
                        </div>
                        <div class="card-body">
                            <table class="table table-borderless">
                                <tbody>
                                    <tr>
                                        <td class="text-muted" width="35%">
                                            <i class="bi bi-tag"></i> Category
                                        </td>
                                        <td class="fw-semibold">@Model.Category</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">
                                            <i class="bi bi-exclamation-triangle"></i> Priority
                                        </td>
                                        <td>
                                            <span class="badge bg-@priorityColor">@Model.Priority</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">
                                            <i class="bi bi-calendar"></i> Submitted
                                        </td>
                                        <td class="fw-semibold">@Model.SubmittedDate.ToString("dd MMM yyyy, hh:mm tt")</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">
                                            <i class="bi bi-chat-left-text"></i> Description
                                        </td>
                                        <td>
                                            <div class="alert alert-light mb-0">
                                                @Model.Description
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                            @if (!string.IsNullOrEmpty(Model.ResolutionNotes))
                            {
                                <div class="alert alert-success mt-3">
                                    <h6 class="alert-heading fw-bold">
                                        <i class="bi bi-clipboard-check"></i> Resolution Notes
                                    </h6>
                                    <p class="mb-0">@Model.ResolutionNotes</p>
                                </div>
                            }

                            @if (Model.ClosedDate.HasValue)
                            {
                                <div class="alert alert-info mt-3">
                                    <i class="bi bi-check2-circle"></i>
                                    <strong>Completed on:</strong> @Model.ClosedDate.Value.ToString("dd MMM yyyy, hh:mm tt")
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Location & Assignment -->
                <div class="col-lg-4">
                    <div class="card mb-3">
                        <div class="card-header bg-white">
                            <h6 class="mb-0 fw-bold">
                                <i class="bi bi-geo-alt"></i> Location
                            </h6>
                        </div>
                        <div class="card-body">
                            <p class="mb-2">
                                <i class="bi bi-building text-primary"></i>
                                <strong>Building:</strong><br />
                                @Model.Building
                            </p>
                            <p class="mb-0">
                                <i class="bi bi-door-open text-primary"></i>
                                <strong>Unit:</strong><br />
                                @Model.Unit
                            </p>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header bg-white">
                            <h6 class="mb-0 fw-bold">
                                <i class="bi bi-person-badge"></i> Assignment
                            </h6>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(Model.AssignedStaff))
                            {
                                <div class="text-center">
                                    <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-2"
                                         style="width: 60px; height: 60px;">
                                        <i class="bi bi-person-check text-success" style="font-size: 2rem;"></i>
                                    </div>
                                    <p class="mb-0 fw-semibold">@Model.AssignedStaff</p>
                                    <small class="text-success">
                                        <i class="bi bi-check-circle-fill"></i> Assigned
                                    </small>
                                </div>
                            }
                            else
                            {
                                <div class="text-center text-muted">
                                    <i class="bi bi-hourglass-split" style="font-size: 2rem;"></i>
                                    <p class="mb-0 mt-2">Not yet assigned</p>
                                    <small>Waiting for technician</small>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="row mt-4">
                <div class="col-12">
                    <div class="d-grid gap-2 d-md-flex justify-content-md-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Search Another Request
                        </a>
                        <button class="btn btn-outline-primary" onclick="window.print()">
                            <i class="bi bi-printer"></i> Print Details
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        @@media print {
            .btn, .navbar, .footer, .page-header {
                display: none !important;
            }
        }
    </style>
}