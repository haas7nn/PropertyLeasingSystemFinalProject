@model PropertyManagement.MVC.Models.MaintenanceLookupDto
@{
    ViewData["Title"] = "Request Status";

    var sc = Model.Status switch {
        "Submitted"  => "s-pending",
        "Assigned"   => "s-assigned",
        "InProgress" => "s-inprogress",
        "Resolved"   => "s-resolved",
        "Closed"     => "s-closed",
        _            => "s-pending"
    };

    int pct = Model.Status switch {
        "Submitted"  => 20,
        "Assigned"   => 40,
        "InProgress" => 60,
        "Resolved"   => 80,
        "Closed"     => 100,
        _            => 0
    };

    var icon = Model.Status switch {
        "Submitted"  => "bi-clock-history",
        "Assigned"   => "bi-person-check",
        "InProgress" => "bi-gear-fill",
        "Resolved"   => "bi-check-circle-fill",
        "Closed"     => "bi-check2-all",
        _            => "bi-question-circle"
    };
}

<div class="page-wrap" style="padding-top:2rem;padding-bottom:2rem;max-width:820px">
  <div class="ph">
    <div>
      <div class="ph-title">Maintenance Request</div>
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Track Request</a></li>
        <li class="breadcrumb-item active">@Model.TicketNumber</li>
      </ol>
    </div>
    <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Search again</a>
  </div>

  <div class="card p-0 mb-3" style="overflow:hidden">
    <div style="background:var(--navy);padding:1.5rem 2rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem">
      <div>
        <div style="color:rgba(255,255,255,.4);font-size:.72rem;letter-spacing:.06em;text-transform:uppercase;font-weight:700">Ticket number</div>
        <div style="color:#fff;font-size:1.6rem;font-weight:800;letter-spacing:-.04em;font-family:'JetBrains Mono',monospace">@Model.TicketNumber</div>
        <div style="color:rgba(255,255,255,.45);font-size:.8rem;margin-top:2px">Submitted @Model.SubmittedDate.ToString("dd MMM yyyy, h:mm tt")</div>
      </div>
      <span class="badge @sc" style="font-size:.85rem;padding:.5em 1em">
        <i class="bi @icon me-1"></i> @Model.Status
      </span>
    </div>

    <div style="padding:.85rem 2rem;background:var(--surface);border-bottom:1px solid var(--border)">
      <div style="display:flex;justify-content:space-between;margin-bottom:.4rem">
        @foreach (var step in new[]{"Submitted","Assigned","In Progress","Resolved","Closed"})
        {
          <span style="font-size:.68rem;font-weight:600;color:var(--muted)">@step</span>
        }
      </div>
      <div style="height:6px;background:var(--border);border-radius:99px;overflow:hidden">
        <div style="height:100%;width:@(pct)%;background:linear-gradient(90deg,var(--brand),#818cf8);border-radius:99px;transition:width .4s"></div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-md-8">
      <div class="card p-4">
        <div style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);margin-bottom:1rem">Request Details</div>
        <table style="width:100%;border-collapse:collapse">
          <tr>
            <td style="width:36%;padding:.5rem 0;color:var(--muted);font-size:.82rem;font-weight:600;vertical-align:top">Category</td>
            <td style="font-size:.88rem;font-weight:600">@Model.Category</td>
          </tr>
          <tr>
            <td style="padding:.5rem 0;color:var(--muted);font-size:.82rem;font-weight:600">Priority</td>
            <td><span class="badge s-pending">@Model.Priority</span></td>
          </tr>
          <tr>
            <td style="padding:.5rem 0;color:var(--muted);font-size:.82rem;font-weight:600;vertical-align:top">Description</td>
            <td style="font-size:.88rem;line-height:1.55">@Model.Description</td>
          </tr>
          <tr>
            <td style="padding:.5rem 0;color:var(--muted);font-size:.82rem;font-weight:600">Building</td>
            <td style="font-size:.88rem">@Model.Building</td>
          </tr>
          <tr>
            <td style="padding:.5rem 0;color:var(--muted);font-size:.82rem;font-weight:600">Unit</td>
            <td style="font-size:.88rem;font-weight:700">@Model.Unit</td>
          </tr>
        </table>
        @if (!string.IsNullOrEmpty(Model.ResolutionNotes))
        {
          <div class="alert alert-success mt-3 mb-0" style="font-size:.85rem">
            <i class="bi bi-clipboard-check"></i> <strong>Resolution Notes:</strong> @Model.ResolutionNotes
          </div>
        }
      </div>
    </div>

    <div class="col-md-4">
      <div class="card p-3 mb-3">
        <div style="font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;font-weight:700;color:var(--muted);margin-bottom:.6rem">Assigned Technician</div>
        @if (!string.IsNullOrEmpty(Model.AssignedStaff))
        {
          <div style="display:flex;align-items:center;gap:.6rem">
            <div style="width:36px;height:36px;background:var(--brand-bg);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--brand);font-size:.85rem;font-weight:700">
              @Model.AssignedStaff[0].ToString().ToUpper()
            </div>
            <div>
              <div style="font-size:.85rem;font-weight:700">@Model.AssignedStaff</div>
              <div style="font-size:.72rem;color:#16a34a"><i class="bi bi-check-circle-fill me-1"></i>Assigned</div>
            </div>
          </div>
        }
        else
        {
          <div style="text-align:center;padding:.5rem 0;color:var(--muted)">
            <i class="bi bi-hourglass-split" style="font-size:1.5rem;display:block;margin-bottom:.4rem"></i>
            <span style="font-size:.82rem">Not yet assigned</span>
          </div>
        }
      </div>

      @if (Model.ClosedDate.HasValue)
      {
        <div class="card p-3 mb-3" style="background:#f0fdf4;border-color:#bbf7d0">
          <div style="font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;font-weight:700;color:#16a34a;margin-bottom:.4rem">Completed</div>
          <div style="font-size:.88rem;font-weight:600">@Model.ClosedDate.Value.ToString("dd MMM yyyy")</div>
        </div>
      }

      <button class="btn btn-secondary btn-sm w-100" onclick="window.print()">
        <i class="bi bi-printer me-1"></i> Print
      </button>
    </div>
  </div>
</div>

@section Scripts {
<style>@@media print { nav, footer, .btn { display:none !important; } }</style>
}
