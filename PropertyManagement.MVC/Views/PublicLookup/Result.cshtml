@model PropertyManagement.MVC.Models.MaintenanceLookupDto

@{
    ViewData["Title"] = "Request Details";

    var statusColor = Model.Status switch
    {
        "Submitted" => "warning",
        "Assigned" => "info",
        "InProgress" => "primary",
        "Resolved" => "success",
        "Closed" => "secondary",
        _ => "secondary"
    };

    var priorityColor = Model.Priority switch
    {
        "Urgent" => "danger",
        "High" => "warning",
        "Medium" => "info",
        "Low" => "secondary",
        _ => "secondary"
    };

    var progressPercent = Model.Status switch
    {
        "Submitted" => 20,
        "Assigned" => 40,
        "InProgress" => 60,
        "Resolved" => 80,
        "Closed" => 100,
        _ => 0
    };
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: 100vh;
    }

    .detail-card {
        background: rgba(255, 255, 255, 0.95);
        border: none;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
    }

    .status-banner {
        background: #212529;
        color: white;
        padding: 30px;
        border-radius: 20px 20px 0 0;
    }

    .info-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        font-weight: 700;
        color: #6c757d;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }

    .info-value {
        font-weight: 500;
        color: #212529;
        margin-bottom: 20px;
    }

    .progress-custom {
        height: 12px;
        border-radius: 10px;
        background-color: #e9ecef;
    }

    .resolution-box {
        background: #f0fff4;
        border-left: 4px solid #28a745;
        padding: 15px;
        border-radius: 8px;
    }

    .btn-back {
        border-radius: 10px;
        padding: 10px 20px;
        transition: all 0.3s;
    }

        .btn-back:hover {
            background-color: #f8f9fa;
            transform: translateX(-5px);
        }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card detail-card mb-4">
                <div class="status-banner d-flex justify-content-between align-items-center">
                    <div>
                        <p class="small opacity-75 mb-1">Ticket Number</p>
                        <h2 class="fw-bold mb-0">@Model.TicketNumber</h2>
                    </div>
                    <div class="text-end">
                        <span class="badge rounded-pill bg-@statusColor px-4 py-2 fs-6">
                            @Model.Status
                        </span>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="mb-5">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="fw-bold small">Current Progress</span>
                            <span class="fw-bold small text-@statusColor">@progressPercent%</span>
                        </div>
                        <div class="progress progress-custom">
                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-@statusColor"
                                 role="progressbar"
                                 style="width: @progressPercent%"></div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="info-label"><i class="bi bi-tag me-1"></i> Category</div>
                            <div class="info-value">@Model.Category</div>

                            <div class="info-label"><i class="bi bi-exclamation-octagon me-1"></i> Priority</div>
                            <div class="info-value">
                                <span class="text-@priorityColor fw-bold">● @Model.Priority</span>
                            </div>

                            <div class="info-label"><i class="bi bi-calendar-event me-1"></i> Submitted</div>
                            <div class="info-value">@Model.SubmittedDate.ToString("dd MMM yyyy, hh:mm tt")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-label"><i class="bi bi-building me-1"></i> Building / Unit</div>
                            <div class="info-value">@Model.Building — Unit @Model.Unit</div>

                            <div class="info-label"><i class="bi bi-person-badge me-1"></i> Assigned Staff</div>
                            <div class="info-value">
                                @(string.IsNullOrEmpty(Model.AssignedStaff) ? "Pending Assignment" : Model.AssignedStaff)
                            </div>

                            @if (Model.ClosedDate.HasValue)
                            {
                                <div class="info-label"><i class="bi bi-check-circle me-1"></i> Completed On</div>
                                <div class="info-value">@Model.ClosedDate.Value.ToString("dd MMM yyyy")</div>
                            }
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="mb-4">
                        <div class="info-label">Issue Description</div>
                        <p class="text-dark">@Model.Description</p>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ResolutionNotes))
                    {
                        <div class="resolution-box">
                            <div class="info-label text-success">Resolution Notes</div>
                            <p class="mb-0 small">@Model.ResolutionNotes</p>
                        </div>
                    }

                    <div class="mt-5">
                        <a asp-action="Index" class="btn btn-outline-secondary btn-back">
                            <i class="bi bi-arrow-left me-2"></i> Track Another Request
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>