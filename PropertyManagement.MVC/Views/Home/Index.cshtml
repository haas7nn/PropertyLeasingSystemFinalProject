@{
    ViewData["Title"] = "Home";
}

<div class="page-header text-center">
    <div class="container">
        <h1 class="display-4 fw-bold mb-3">Welcome to Property Management</h1>
        <p class="lead mb-0">Your complete solution for property leasing and maintenance</p>
    </div>
</div>

<div class="container">
    <div class="row g-4 mb-5">
        <!-- Feature 1 -->
        <div class="col-md-4">
            <div class="card h-100 text-center">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-buildings text-primary" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="card-title">Multiple Properties</h5>
                    <p class="card-text text-muted">
                        Manage multiple buildings and units from a single platform
                    </p>
                </div>
            </div>
        </div>

        <!-- Feature 2 -->
        <div class="col-md-4">
            <div class="card h-100 text-center">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-tools text-success" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="card-title">Maintenance Tracking</h5>
                    <p class="card-text text-muted">
                        Track maintenance requests from submission to completion
                    </p>
                </div>
            </div>
        </div>

        <!-- Feature 3 -->
        <div class="col-md-4">
            <div class="card h-100 text-center">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-shield-check text-info" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="card-title">Secure & Reliable</h5>
                    <p class="card-text text-muted">
                        Your data is protected with industry-standard security
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Main CTA -->
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="card-body text-white text-center p-5">
                    <i class="bi bi-search-heart mb-3" style="font-size: 4rem;"></i>
                    <h2 class="fw-bold mb-3">Track Your Maintenance Request</h2>
                    <p class="lead mb-4">
                        Enter your ticket number to check the status of your maintenance request in real-time
                    </p>
                    <a asp-controller="PublicLookup" asp-action="Index" class="btn btn-light btn-lg px-5">
                        <i class="bi bi-arrow-right-circle"></i> Track Now
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- How It Works -->
    <div class="row mt-5">
        <div class="col-12">
            <h2 class="text-center mb-4 fw-bold">How It Works</h2>
        </div>

        <div class="col-md-3 text-center">
            <div class="mb-3">
                <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center"
                     style="width: 80px; height: 80px; font-size: 2rem;">
                    1
                </div>
            </div>
            <h5>Submit Request</h5>
            <p class="text-muted">Report your maintenance issue</p>
        </div>

        <div class="col-md-3 text-center">
            <div class="mb-3">
                <div class="rounded-circle bg-info text-white d-inline-flex align-items-center justify-content-center"
                     style="width: 80px; height: 80px; font-size: 2rem;">
                    2
                </div>
            </div>
            <h5>Get Ticket Number</h5>
            <p class="text-muted">Receive a unique tracking number</p>
        </div>

        <div class="col-md-3 text-center">
            <div class="mb-3">
                <div class="rounded-circle bg-warning text-white d-inline-flex align-items-center justify-content-center"
                     style="width: 80px; height: 80px; font-size: 2rem;">
                    3
                </div>
            </div>
            <h5>Track Progress</h5>
            <p class="text-muted">Monitor status updates online</p>
        </div>

        <div class="col-md-3 text-center">
            <div class="mb-3">
                <div class="rounded-circle bg-success text-white d-inline-flex align-items-center justify-content-center"
                     style="width: 80px; height: 80px; font-size: 2rem;">
                    4
                </div>
            </div>
            <h5>Issue Resolved</h5>
            <p class="text-muted">Get notified when complete</p>
        </div>
    </div>
</div>