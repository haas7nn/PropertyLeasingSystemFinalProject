@model PropertyManagement.MVC.Models.ErrorViewModel
@{ ViewData["Title"] = "Error"; }
<div style="min-height:calc(100vh - 160px);display:flex;align-items:center;justify-content:center;padding:2rem">
  <div class="text-center" style="max-width:480px">
    <div style="width:72px;height:72px;background:#fef2f2;border-radius:20px;display:inline-flex;align-items:center;justify-content:center;font-size:2rem;color:#dc2626;margin-bottom:1.5rem"><i class="bi bi-exclamation-triangle"></i></div>
    <h1 style="font-size:1.5rem;font-weight:800;letter-spacing:-.03em;color:var(--navy);margin-bottom:.5rem">Something went wrong</h1>
    <p style="color:var(--muted);font-size:.9rem;margin-bottom:1rem">An unexpected error occurred. Please try again or contact support.</p>
    @if (Model?.ShowRequestId == true)
    {
      <p style="font-family:'DM Mono',monospace;font-size:.75rem;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:.5rem 1rem;color:var(--muted);margin-bottom:1.5rem">Request ID: @Model.RequestId</p>
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Back to Dashboard</a>
  </div>
</div>
