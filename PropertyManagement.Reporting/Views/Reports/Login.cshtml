@{ ViewData["Title"] = "Reporting Login"; Layout = "_Layout"; }

<div class="container mt-5" style="max-width:440px">
  <div class="card p-4 shadow-sm text-center">
    <i class="bi bi-bar-chart-fill fs-1 text-primary mb-2"></i>
    <h2 class="fw-bold mb-1" style="font-size:1.3rem">Property Management Reports</h2>
    <p class="text-muted small mb-1">Sign in with your <strong>Property Manager</strong> account.</p>
    <p class="text-muted" style="font-size:.73rem;margin-bottom:1.25rem">
      Enter your Property Manager credentials to access reports.
    </p>

    @if (ViewBag.Error != null)
    {
      <div class="alert alert-danger py-2 small">@ViewBag.Error</div>
    }

    <form method="post" asp-action="Login">
      @Html.AntiForgeryToken()
      <div class="mb-3 text-start">
        <label class="form-label fw-semibold small">Email</label>
        <input type="email" name="email" class="form-control"
               placeholder="manager@propmanager.com" autofocus required />
      </div>
      <div class="mb-4 text-start">
        <label class="form-label fw-semibold small">Password</label>
        <input type="password" name="password" class="form-control"
               placeholder="Your account password" required />
      </div>
      <button type="submit" class="btn btn-primary w-100">
        <i class="bi bi-shield-lock me-1"></i> Sign In
      </button>
    </form>

    <hr class="my-3">
    <p class="text-muted" style="font-size:.72rem">
      <i class="bi bi-info-circle me-1"></i>
      Access is restricted to Property Manager accounts only.
    </p>
  </div>
</div>
