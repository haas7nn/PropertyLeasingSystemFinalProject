@model PropertyManagement.Reporting.Models.MaintenanceStatsReport
@{
    ViewData["Title"] = "Maintenance";
    ViewData["ActivePage"] = "Maintenance";
}
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <div class="page-title">Maintenance Statistics</div>
        <div class="page-sub">Request backlog and resolution times</div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="kpi">
            <div class="kpi-icon" style="background:#eff6ff;color:var(--blue)"><i class="bi bi-list-check"></i></div>
            <div><div class="kpi-num">@Model.TotalRequests</div><div class="kpi-label">Total Requests</div></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi">
            <div class="kpi-icon" style="background:#fffbeb;color:#d97706"><i class="bi bi-stopwatch"></i></div>
            <div><div class="kpi-num" style="color:#d97706">@Model.AverageResolutionDays</div><div class="kpi-label">Avg Days to Resolve</div></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi">
            <div class="kpi-icon" style="background:#fef2f2;color:#dc2626"><i class="bi bi-lightning-charge"></i></div>
            <div><div class="kpi-num" style="color:#dc2626">@(Model.ByPriority.FirstOrDefault(p => p.Priority == "Urgent")?.Count ?? 0)</div><div class="kpi-label">Urgent</div></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi">
            <div class="kpi-icon" style="background:#f0fdf4;color:#16a34a"><i class="bi bi-check2-all"></i></div>
            <div><div class="kpi-num" style="color:#16a34a">@(Model.ByStatus.FirstOrDefault(s => s.Status == "Closed")?.Count ?? 0)</div><div class="kpi-label">Closed</div></div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card p-4">
            <div style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:.75rem">By Status</div>
            @foreach (var s in Model.ByStatus)
            {
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span style="font-size:.85rem">@s.Status</span>
                    <span style="background:#f1f5f9;color:#334155;font-size:.78rem;font-weight:700;padding:2px 10px;border-radius:99px">@s.Count</span>
                </div>
            }
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-4">
            <div style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:.75rem">By Category</div>
            @foreach (var c in Model.ByCategory)
            {
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span style="font-size:.85rem">@c.Category</span>
                    <span style="background:#eff6ff;color:#1d4ed8;font-size:.78rem;font-weight:700;padding:2px 10px;border-radius:99px">@c.Count</span>
                </div>
            }
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-4">
            <div style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:.75rem">By Priority</div>
            @foreach (var p in Model.ByPriority)
            {
                string bg, fg;
                if (p.Priority == "Urgent")      { bg = "#fef2f2"; fg = "#dc2626"; }
                else if (p.Priority == "High")   { bg = "#fffbeb"; fg = "#d97706"; }
                else if (p.Priority == "Medium") { bg = "#eff6ff"; fg = "#1d4ed8"; }
                else                             { bg = "#f1f5f9"; fg = "#64748b"; }

                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span style="font-size:.85rem">@p.Priority</span>
                    <span style="background:@bg;color:@fg;font-size:.78rem;font-weight:700;padding:2px 10px;border-radius:99px">@p.Count</span>
                </div>
            }
        </div>
    </div>
</div>
